{
  "name": "pos-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:store": "pnpm --filter store-app dev",
    "dev:admin": "pnpm --filter admin-app dev",
    "dev:all": "pnpm --parallel --filter \"./apps/*\" dev",
    "build": "echo 'ERROR: Cannot build from root. Netlify must set base directory to apps/store-app or apps/admin-app. See NETLIFY_DEPLOYMENT_STEP_BY_STEP.md' && exit 1",
    "build:store": "pnpm --filter store-app build",
    "build:admin": "pnpm --filter admin-app build",
    "build:all": "pnpm --filter \"./apps/*\" build",
    "dist:store": "pnpm --filter store-app dist",
    "pack:store": "pnpm --filter store-app pack",
    "lint": "pnpm --filter \"./apps/*\" lint",
    "clean": "pnpm --recursive exec rm -rf node_modules dist dist-electron",
    "setup": "pnpm install"
  },
  "devDependencies": {
    "electron": "^38.5.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.20.0"
}
