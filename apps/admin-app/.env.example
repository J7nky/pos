# Copy to .env and fill in real values. Never commit .env with secrets.

# Required: Supabase project
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: service role for admin-only operations (use with care; never expose in public builds)
# VITE_SUPABASE_SERVICE_ROLE_KEY=

# Declared in vite-env.d.ts — set if your admin app reads them
# VITE_API_URL=https://api.example.com
# VITE_APP_TITLE=POS Admin

# Public base URL (mirrors store-app pattern in vite.config)
# VITE_PUBLIC_URL=http://localhost:5179
