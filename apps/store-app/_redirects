# Netlify redirects file (backup for netlify.toml)
# This ensures SPA routing works correctly

# IMPORTANT: Exclude /updates/* from SPA redirect (MUST come before catch-all)
# This allows update files to be served directly
/updates/*    /updates/:splat    200

# Redirect all routes to index.html for SPA routing
/*    /index.html   200

# Specific redirect for public customer statement routes
/public/customer-statement/*    /index.html   200
