# Copy to .env and fill in real values. Never commit .env with secrets.

# Required: Supabase project (anon key is safe for client-side; keep service role server-side only)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: service role — only if a feature explicitly needs it in this app (prefer Edge Functions)
# VITE_SUPABASE_SERVICE_ROLE_KEY=

# Public base URL for links (e.g. QR receipts). Defaults in vite.config if unset.
# VITE_PUBLIC_URL=http://localhost:5178

# Optional: verbose event-stream / catch-up logs (default off)
# VITE_EVENT_STREAM_VERBOSE=true
